# Modal API credentials
# Get your token from https://modal.com/settings/tokens
# Run: modal token set --token-id <TOKEN_ID> --token-secret <TOKEN_SECRET>
MODAL_TOKEN_ID=your-modal-token-id-here
MODAL_TOKEN_SECRET=your-modal-token-secret-here

# Supabase credentials
# Get these from your Supabase project: Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
